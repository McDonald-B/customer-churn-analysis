      <aliases enabled='yes' />
      <column caption='Total Customers' datatype='integer' name='[Calculation_2385691100696576]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD([customerID])' />
      </column>
      <column caption='Churn Rate' datatype='real' default-format='p0.00%' name='[Calculation_2385691101016065]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Churn_Flag]) / COUNTD([customerID])' />
      </column>
      <column caption='Customers Lost' datatype='integer' name='[Calculation_2385691104317442]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Churn_Flag])' />
      </column>
      <column caption='Monthly Revenue Lost' datatype='real' default-format='c&quot;£&quot;#,##0;-&quot;£&quot;#,##0' name='[Calculation_2385691104899075]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(&#13;&#10;IF [Churn_Flag] = 1&#13;&#10;THEN [MonthlyCharges]&#13;&#10;END&#13;&#10;)' />
      </column>
      <column caption='Lifetime Value Lost' datatype='real' default-format='c&quot;£&quot;#,##0.00;-&quot;£&quot;#,##0.00' name='[Calculation_2385691105669124]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(&#13;&#10;IF [Churn_Flag] = 1&#13;&#10;THEN [Customer_Lifetime_Value]&#13;&#10;END&#13;&#10;)' />
      </column>
      <column caption='Churn Flag' datatype='integer' name='[Churn_Flag]' role='measure' type='quantitative' />
      <column datatype='string' name='[Contract]' role='dimension' type='nominal' />
      <column caption='Customer Lifetime Value' datatype='real' name='[Customer_Lifetime_Value]' role='measure' type='quantitative' />
