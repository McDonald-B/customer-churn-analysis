                  <zone fixed-size='215' forceUpdate='true' h='15928' id='32' is-fixed='true' type-v2='text' w='86500' x='1750' y='75095'>
                    <formatted-text>
                      <run fontcolor='#000000' fontsize='12' underline='true'>Key Insights Box</run>
                      <run>Æ&#10;</run>
                      <run fontcolor='#000000'>Summary of the main findings from the analysis</run>
                      <run>Æ&#10;&#10;</run>
                      <run fontcolor='#000000' fontsize='12'>• Overall churn rate is 26.6%, with 1,869 customers lost.</run>
                      <run>Æ&#10;</run>
                      <run fontcolor='#000000' fontsize='12'>• Month-to-month customers have the highest churn rate (42.7%), </run>
                      <run>Æ&#10;</run>
                      <run fontcolor='#000000' fontsize='12'>  significantly higher than one-year (11.3%) and two-year contracts (2.9%).</run>
                      <run>Æ&#10;</run>
                      <run fontcolor='#000000' fontsize='12'>• Customers within their first 12 months show the highest churn risk (47.7%).</run>
                      <run>Æ&#10;</run>
                      <run fontcolor='#000000' fontsize='12'>• Fiber optic customers experience the highest churn rate (41.9%).</run>
                      <run>Æ&#10;</run>
                      <run fontcolor='#000000' fontsize='12'>• Electronic check users have the highest churn rate (45.3%).</run>
                    </formatted-text>
                    <zone-style>
                      <format attr='border-color' value='#000000' />
                      <format attr='border-style' value='none' />
                      <format attr='border-width' value='0' />
                      <format attr='margin' value='4' />
                    </zone-style>
                  </zone>
                  <zone forceUpdate='true' h='6642' id='33' type-v2='text' w='86500' x='1750' y='91023'>
                    <formatted-text>
